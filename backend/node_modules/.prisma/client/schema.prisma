generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USER =====
model User {
  id                    String    @id @default(cuid())
  walletAddress         String    @unique
  email                 String?   @unique
  username              String?   @unique
  displayName           String?
  profileImage          String?
  apiKey                String?   @unique
  twoFactorEnabled      Boolean   @default(false)
  twoFactorSecret       String?
  twoFactorBackupCodes  String?   // JSON array of backup codes
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  escrowsAsClient       Escrow[]  @relation("client")
  escrowsAsFreelancer   Escrow[]  @relation("freelancer")
  creditScore           CreditScore?
  settings              UserSettings?
  borrows               Borrow[]
  transactions          Transaction[]
  ratingsSent           Rating[]  @relation("rater")
  ratingsReceived       Rating[]  @relation("rated")

  @@index([walletAddress])
}

// ===== USER SETTINGS =====
model UserSettings {
  id                    String    @id @default(cuid())
  userId                String    @unique
  theme                 String    @default("dark") // "dark" or "light"
  emailNotifications    Boolean   @default(true)
  transactionAlerts     Boolean   @default(true)
  publicProfile         Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== CREDIT SCORE =====
model CreditScore {
  id                String    @id @default(cuid())
  userId            String    @unique
  rating            Int       @default(50) // 0-100
  tier              String    @default("TIER_4") // TIER_1, TIER_2, TIER_3, TIER_4
  borrowLimit       BigInt    @default(0)
  totalCompleted    Int       @default(0)
  totalEarned       BigInt    @default(0)
  onTimeReleases    Int       @default(0)
  disputeCount      Int       @default(0)
  refundedCount     Int       @default(0)
  lastUpdated       DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([rating])
  @@index([tier])
}

// ===== ESCROW =====
model Escrow {
  id                String    @id @default(cuid())
  suiEscrowId       String?   @unique
  clientId          String
  freelancerId      String
  jobTitle          String
  jobDescription    String?
  category          String?   // "dev", "design", "writing", etc
  totalAmount       BigInt
  releasedAmount    BigInt    @default(0)
  milestoneCount    Int
  completedMilestones Int    @default(0)
  status            String    @default("ACTIVE") // ACTIVE, RELEASED, DISPUTED, COMPLETED
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  estimatedEnd      DateTime?

  // Relations
  client            User      @relation("client", fields: [clientId], references: [id])
  freelancer        User      @relation("freelancer", fields: [freelancerId], references: [id])
  milestones        Milestone[]
  transactions      Transaction[]
  dispute           Dispute?

  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
  @@index([createdAt])
}

// ===== MILESTONE =====
model Milestone {
  id                String    @id @default(cuid())
  escrowId          String
  milestoneNum      Int
  title             String
  description       String?
  amount            BigInt
  status            String    @default("PENDING") // PENDING, RELEASED, DISPUTED
  releaseCondition  String    @default("CLIENT_APPROVAL") // CLIENT_APPROVAL, MILESTONE_COMPLETE
  releaseDeadline   DateTime?
  releasedAt        DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  escrow            Escrow    @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@unique([escrowId, milestoneNum])
  @@index([escrowId])
  @@index([status])
}

// ===== DISPUTE =====
model Dispute {
  id                String    @id @default(cuid())
  escrowId          String    @unique
  reason            String
  evidence          String?   // JSON field for attachments
  status            String    @default("OPEN") // OPEN, RESOLVED, REFUNDED
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  escrow            Escrow    @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ===== BORROW =====
model Borrow {
  id                String    @id @default(cuid())
  borrowerId        String
  amount            BigInt
  interestRate      Float     @default(5.0) // 5% APY
  repaymentSchedule String    // JSON: {dueDate, amount}[]
  status            String    @default("ACTIVE") // ACTIVE, REPAID, DEFAULTED
  createdAt         DateTime  @default(now())
  dueDate           DateTime
  repaidAt          DateTime?

  // Relations
  borrower          User      @relation(fields: [borrowerId], references: [id])
  transactions      Transaction[]

  @@index([borrowerId])
  @@index([status])
}

// ===== TRANSACTION =====
model Transaction {
  id                String    @id @default(cuid())
  userId            String
  escrowId          String?
  borrowId          String?
  txHash            String    @unique
  type              String    // "DEPOSIT", "RELEASE", "BORROW", "REPAY"
  amount            BigInt
  status            String    @default("PENDING") // PENDING, CONFIRMED, FAILED
  createdAt         DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id])
  escrow            Escrow?   @relation(fields: [escrowId], references: [id])
  borrow            Borrow?   @relation(fields: [borrowId], references: [id])

  @@index([userId])
  @@index([txHash])
  @@index([status])
}

// ===== RATING =====
model Rating {
  id                String    @id @default(cuid())
  raterId           String
  ratedId           String
  escrowId          String
  rating            Int       // 1-5 stars
  comment           String?
  createdAt         DateTime  @default(now())

  // Relations
  rater             User      @relation("rater", fields: [raterId], references: [id])
  rated             User      @relation("rated", fields: [ratedId], references: [id])

  @@unique([raterId, escrowId])
  @@index([ratedId])
}
